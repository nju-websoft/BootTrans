local function count_distinct_elements(nums)

lu = require('luaunit')

function test_humaneval()
    lu.assertEquals(count_distinct_elements({}), 0)
    lu.assertEquals(count_distinct_elements({1}), 1)
    lu.assertEquals(count_distinct_elements({1, 2, 3, 4, 5}), 5)
    lu.assertEquals(count_distinct_elements({2, 2, 2, 2, 2}), 1)
    lu.assertEquals(count_distinct_elements({1, 2, 2, 3, 3, 4, 5, 6, 6}), 6)
    lu.assertEquals(count_distinct_elements({-1, -1, 0, 1, 1, 2, 2}), 4)
end

os.exit(lu.LuaUnit.run())
